# غيّر القيم حسب مشروعك
# SUPABASE_URL=...
# SUPABASE_KEY=...


# لوحة تحكم ويب (اختياري، يمكنك الاعتماد على /admin فقط)
ADMIN_PASSWORD=CHANGE_ME
ADMIN_SECRET=CHANGE_ME_SECRET
# رابط لوحة الأدمن (خدمة الويب) - مثال: https://your-admin.up.railway.app
# يستخدمه زر "لوحة الويب" في /admin
ADMIN_DASHBOARD_URL=https://admin-frontend-production-cd40.up.railway.app

# وضع Webhook (اختياري): تشغيل البوت كخادم ويب لاستقبال التحديثات عبر HTTPS
# اتركه معطلاً للاستخدام العادي (Polling). فعّله إذا كان لديك نطاق HTTPS عام.
# USE_WEBHOOK=false
# WEBHOOK_URL=https://your-domain.com
# WEBHOOK_PORT=8080
# WEBHOOK_PATH=webhook
# WEBHOOK_LISTEN=0.0.0.0

# Gemini (لرسالة التغطية التلقائية): من https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# قناة مصدر الوظائف: معرّف القناة (رقم سالب مثل -1001234567890). البوت يجب أن يكون أدمن في القناة.
# اتركه فارغاً لتعطيل استيراد الوظائف من القناة.
# JOBS_SOURCE_CHANNEL_ID=

# إرسال البريد: Gmail SMTP (465، 587). DigitalOcean يحجب هذه المنافذ افتراضياً على Droplets.
# Railway قد تحجب SMTP أيضاً. لضمان الإرسال: جهازك أو VPS لا يحجب SMTP (مثل Hetzner)، أو Gmail API لاحقاً.

# Resend (اختياري): عند تعيين المفتاح والبريد سيستخدم البوت Resend بدل SMTP
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM_EMAIL=apply@yourdomain.com
# RESEND_FROM_NAME=Jobsa Bot
# RESEND_ALIAS_DOMAIN=yourdomain.com
